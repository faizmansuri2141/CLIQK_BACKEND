<body>
    <div class="theme-loader">
        <div class="ball-scale">
            <div class='contain'>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
                <div class="ring"><div class="frame"></div></div>
            </div>
        </div>
    </div>

    <div id="pcoded" class="pcoded">
        <div class="pcoded-overlay-box"></div>
        <div class="pcoded-container navbar-wrapper">

            {{>header}}

            <div class="pcoded-main-container">
                <div class="pcoded-wrapper">

                    {{>sidebar}}
                    
                    <div class="pcoded-content">
                        <div class="pcoded-inner-content">

                            <div class="main-body">
                                <div class="page-wrapper">

                                    <div class="page-header">
                                        <div class="row align-items-end">
                                            <div class="col-lg-8">
                                                <div class="page-header-title">
                                                    <div class="d-inline">
                                                        <h4>Sections Rewards</h4>
                                                        <span>Manage section weekly winner rewards</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-lg-4">
                                                <div class="page-header-breadcrumb">
                                                    <ul class="breadcrumb-title">
                                                        <li class="breadcrumb-item" style="float: left;">
                                                            <a href="/"> <i class="feather icon-home"></i> </a>
                                                        </li>
                                                        <li class="breadcrumb-item" style="float: left;">
                                                            <a href="dashboard">Dashboard</a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="page-body">
                                        <div class="row">
                                            <div class="col-sm-12">
                                                <div class="card">
                                                    <div class="card-header table-card-header">
                                                        <h5>Pending Section Rewards ({{pendingCount}})</h5>
                                                    </div>
                                                    <div class="card-block">
                                                        <div class="dt-responsive table-responsive">
                                                            <table id="basic-btn" class="table table-striped table-bordered nowrap text-center">
                                                                <thead>
                                                                    <tr>
                                                                        <th>Section & Owner</th>
                                                                        <th>Details</th>
                                                                        <th>Submitted Date</th>
                                                                        <th>Action</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    {{#each rewards}}
                                                                    <tr>
                                                                        <td>
                                                                            <div class="d-flex align-items-center">
                                                                                <div class="bg-light rounded p-2 me-2">
                                                                                    <i class="fa fa-users fa-lg text-primary"></i>
                                                                                </div>
                                                                                <div class="text-start">
                                                                                    <strong>{{this.section_id.communityName}}</strong><br>
                                                                                    <small class="text-muted">
                                                                                        Owner: {{this.user_id.fullname}}
                                                                                    </small><br>
                                                                                    <span class="badge badge-info">Section Winner</span>
                                                                                </div>
                                                                            </div>
                                                                        </td>
                                                                        <td class="text-start">
                                                                            {{#if this.reward_details.song_title}}
                                                                            <strong>Song:</strong> {{this.reward_details.song_title}}<br>
                                                                            {{/if}}
                                                                            {{#if this.reward_details.genre}}
                                                                            <strong>Genre:</strong> {{this.reward_details.genre}}<br>
                                                                            {{/if}}
                                                                            {{#if this.reward_details.theme}}
                                                                            <strong>Theme:</strong> {{this.reward_details.theme}}<br>
                                                                            {{/if}}
                                                                            <small class="text-muted">
                                                                                Week: {{formatDate this.week_start_date}} to {{formatDate this.week_end_date}}
                                                                            </small>
                                                                        </td>
                                                                        <td>{{formatDate this.submitted_at}}</td>
                                                                        <td>
                                                                            <button type="button" 
                                                                                    class="btn btn-info btn-sm" 
                                                                                    onclick="openVideoUpload('{{this._id}}', '{{this.section_id.communityName}}', 'section')">
                                                                                <i class="fa fa-video-camera"></i> Upload Video
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                    {{else}}
                                                                    <tr>
                                                                        <td colspan="4" class="text-center">
                                                                            <div class="py-4">
                                                                                <i class="fa fa-users fa-3x text-muted mb-3"></i>
                                                                                <h5>No Pending Section Rewards</h5>
                                                                                <p class="text-muted">There are no pending section reward claims at the moment.</p>
                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    {{/each}}
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Same Video Upload Modal as users-rewards.hbs -->
    <div class="modal fade" id="videoUploadModal" tabindex="-1" role="dialog" aria-labelledby="videoUploadModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="videoUploadModalLabel">
                        <i class="fa fa-video-camera me-2"></i>Upload Congratulations Video
                    </h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="videoUploadForm" enctype="multipart/form-data">
                        <input type="hidden" id="rewardId" name="rewardId">
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="video_title" class="form-label">Video Title *</label>
                                    <input type="text" class="form-control" id="video_title" name="video_title" 
                                           value="Congratulations Video" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="video_file" class="form-label">Upload Video *</label>
                                    <input type="file" class="form-control" id="video_file" name="video" 
                                           accept="video/*" required>
                                    <small class="form-text text-muted">Supported: MP4, MOV, AVI. Max: 50MB</small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="video_description" class="form-label">Video Description</label>
                            <textarea class="form-control" id="video_description" name="video_description" 
                                      rows="2" placeholder="Add a description for the video..."></textarea>
                        </div>

                        <div class="form-group">
                            <label for="admin_notes" class="form-label">Message for Winner</label>
                            <textarea class="form-control" id="admin_notes" name="admin_notes" 
                                      rows="2" placeholder="Write a congratulatory message..."></textarea>
                        </div>

                        <!-- Video Preview -->
                        <div id="videoPreviewContainer" style="display: none;">
                            <label class="form-label">Video Preview:</label>
                            <video id="videoPreview" class="w-100" controls style="max-height: 200px; border-radius: 8px;">
                                Your browser does not support the video tag.
                            </video>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="uploadVideo()">
                        <i class="fa fa-upload me-2"></i>Upload & Complete Reward
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Same JavaScript as users-rewards.hbs
        let currentRewardId = null;
        
        function openVideoUpload(rewardId, sectionName, rewardType) {
            currentRewardId = rewardId;
            document.getElementById('rewardId').value = rewardId;
            document.getElementById('videoUploadForm').reset();
            document.getElementById('videoPreviewContainer').style.display = 'none';
            $('#videoUploadModal').modal('show');
        }
        
        document.getElementById('video_file').addEventListener('change', function(e) {
            const file = e.target.files[0];
            const preview = document.getElementById('videoPreview');
            const previewContainer = document.getElementById('videoPreviewContainer');
            
            if (file) {
                const url = URL.createObjectURL(file);
                preview.src = url;
                previewContainer.style.display = 'block';
            } else {
                previewContainer.style.display = 'none';
            }
        });
        
        async function uploadVideo() {
            const form = document.getElementById('videoUploadForm');
            const formData = new FormData(form);
            
            const submitBtn = document.querySelector('#videoUploadModal .btn-primary');
            const originalText = submitBtn.innerHTML;
            
            try {
                submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Uploading...';
                submitBtn.disabled = true;
                
                const response = await fetch(`/admin/upload-video/${currentRewardId}`, {
                    method: 'PUT',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert('🎉 Video uploaded successfully! Reward completed.');
                    $('#videoUploadModal').modal('hide');
                    location.reload();
                } else {
                    throw new Error(result.message);
                }
                
            } catch (error) {
                console.error('Upload error:', error);
                alert('❌ Error uploading video: ' + error.message);
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        }
        
        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString();
        }
    </script>
</body>