<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Upload Imoji</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
  <style>
    .btn-dark {
      background-color: #000 !important;
      border-color: #000 !important;
    }

    #preview {
      max-width: 100%;
      max-height: 300px;
      margin-top: 10px;
      display: none;
      border-radius: 8px;
      border: 1px solid #ccc;
    }
  </style>
</head>
<body>

  <!-- Loader -->
  <div class="theme-loader">
    <div class="ball-scale">
      <div class='contain'>
      </div>
    </div>
  </div>

  <div id="pcoded" class="pcoded">
    <div class="pcoded-overlay-box"></div>
    <div class="pcoded-container navbar-wrapper">

      {{> header }}

      <div class="pcoded-main-container">
        <div class="pcoded-wrapper">

          {{> sidebar }}

          <div class="pcoded-content">
            <div class="pcoded-inner-content">

              <div class="main-body">
                <div class="page-wrapper">

                  <div class="page-header">
                    <div class="row align-items-end">
                      <div class="col-lg-8">
                        <div class="page-header-title">
                          <div class="d-inline">
                            <h4>Upload Imoji</h4>
                            <span>Upload a new imoji with preview</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Main Upload Form -->
                  <div class="page-body">
                    <div class="row">
                      <div class="col-md-6 offset-md-3">
                        <div class="card">
                          <div class="card-header">
                            <h5 class="text-center">Create New Imoji</h5>
                          </div>
                          <div class="card-block">
                            <form action="/imojisUpload" method="POST" enctype="multipart/form-data">
                              <div class="form-group">
                                <label for="imojiName">Imoji Name</label>
                                <input type="text" class="form-control" id="imojiName" name="imojiName" required>
                              </div>

                              <div class="form-group mt-3">
                                <label for="imojiImage">Imoji Image (Upload)</label>
                                <input type="file" class="form-control" id="imojiImage" name="imojiImage" accept="image/*" required>
                                <img id="preview" class="img-thumbnail mt-2"/>
                              </div>

                              <button type="submit" class="btn btn-dark btn-block mt-4 w-100">Upload Imoji</button>
                            </form>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <!-- End Upload Form -->

                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Image Preview Script -->
  <script>
    const imojiInput = document.getElementById("imojiImage");
    const preview = document.getElementById("preview");

    imojiInput.addEventListener("change", function () {
      const file = this.files[0];
      if (file) {
        preview.src = URL.createObjectURL(file);
        preview.style.display = "block";
      } else {
        preview.style.display = "none";
      }
    });
  </script>
</body>
</html>
