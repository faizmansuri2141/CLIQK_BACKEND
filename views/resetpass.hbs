                                        <p class="text-inverse text-left"><a href=""><b class="f-w-600">Back
                                                    to website</b></a></p>
                                    </div> --}}
                                    <div class="col-md-2">
                                        {{!-- <img src="images/auth/Logo-small-bottom.png" alt="small-logo.png"> --}}
                                    </div>
                                </div>
