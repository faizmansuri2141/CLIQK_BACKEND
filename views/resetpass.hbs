    <section class="login-block" ;>

        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12">

                    <form class="md-float-material form-material" action="/forgetpassword/{{userId}}/{{token}}" method="post">
                        <div class="text-center">
                            {{!-- {{process.env.BASE_URL}}/ --}}
                        </div>
                        <div class="auth-box card">
                            <div class="card-block" style="background-color: black;">
                                <div class="row m-b-20">
                                    <div class="col-md-12">
                                        {{!-- <img src="{{process.env.BASE_URL}}/assets/images/splash_logo.png"
                                            class="text-center" height="100px" width="100px" alt="logo.png">
                                        --}}
                                        <div class="text-center">
                                            <img src="/assets/images/splash_logo_CLIQK.png" alt="logo.png"
                                                class="text-center" height="80px" width="80px" />

                                        </div>
                                        <br>
                                        {{#if success}}
                                        <div class="alert alert-success border-success">
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                                <i class="icofont icofont-close-line-circled"></i>
                                            </button>
                                            <strong>{{success}}</strong>
                                        </div>
                                        {{/if}}

                                        <h3 class="text-center" style="color: ffffff;">Reset your password</h3>
                                    </div>
                                </div>
                                <div class="form-group form-primary">
                                    <input type="password" name="Password" class="form-control" required="true"
                                        placeholder="Your New Password">
                                    <span class="form-bar"></span>
                                </div>
                                <div class="row">
                                    <div class="col-md-12">
                                        <button type="submit"
                                            class="btn btn-primary btn-md btn-block waves-effect text-center m-b-20"
                                            style="background-color:  black;">Reset
                                            Password</button>
                                    </div>
                                </div>
                                {{!-- <p class="f-w-600 text-right">Back to <a
                                        href="auth-normal-sign-in.html">Login.</a></p> --}}
                                <div class="row">
                                    {{!-- <div class="col-md-10">
