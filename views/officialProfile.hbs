<body>

    <style>
        /* Styles for the "Is Official" button */
        .btn-official {
            background-color: #4CAF50;
            /* Green background color */
            color: #fff;
            /* White text color */
            font-weight: bold;
            font-size: 14px;
            border: none;
            border-radius: 12px;
            padding: 10px 20px;
            cursor: pointer;
        }

        /* Hover effect for "Is Official" button */
        .btn-official:hover {
            background-color: #45a049;
            /* Darker green on hover */
        }

        /* Styles for the "Is Not Official" button */
        .btn-not-official {
            background-color: #f44336;
            /* Red background color */
            color: #fff;
            /* White text color */
            font-weight: bold;
            font-size: 14px;
            border: none;
            border-radius: 12px;
            padding: 10px 20px;
            cursor: pointer;
        }

        /* Hover effect for "Is Not Official" button */
        .btn-not-official:hover {
            background-color: #d32f2f;
            /* Darker red on hover */
        }

        .image_div {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: auto;

        }

        .image_div_inner {
            width: 3400px;
            height: 340px;
        }

        .image_div_inner img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
    </style>

    <div class="theme-loader">
        <div class="ball-scale">
            <div class='contain'>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
                <div class="ring">
                    <div class="frame"></div>
                </div>
            </div>
        </div>
    </div>

    <div id="pcoded" class="pcoded">
        <div class="pcoded-overlay-box"></div>
        <div class="pcoded-container navbar-wrapper">


            {{>header}}


            <div class="pcoded-main-container">
                <div class="pcoded-wrapper">


                    {{>sidebar}}
                    <div class="pcoded-content">
                        <div class="pcoded-inner-content">


                            <div class="main-body">
                                <div class="page-wrapper">

                                    <div class="page-header">
                                        <div class="row align-items-end">
                                            <div class="col-lg-8">
                                                <div class="page-header-title">
                                                    <div class="d-inline">
                                                        <h4>Applying For Blue Tick</h4>
                                                        <span></span>
                                                    </div>
                                                </div>
                                            </div>
                                            {{!-- <div class="col-lg-4">
                                                <div class="page-header-breadcrumb">
                                                    <ul class="breadcrumb-title">
                                                        <li class="breadcrumb-item" style="float: left;">
                                                            <a href="/"> <i class="feather icon-home"></i>
                                                            </a>
                                                        </li>
                                                        <li class="breadcrumb-item" style="float: left;"><a
                                                                href="dashboard">Dashboard</a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div> --}}
                                        </div>
                                    </div>
                                    <div class="page-body">
                                        <div style="width: 100%;">
                                            <div class="">
                                                <div class="card user-card-full">
                                                    <div class="row m-l-0 m-r-0">
                                                        <div class="" style="background-color: black;">
                                                            <div
                                                                class="card-block text-center text-white d-flex align-items-center justify-content-center flex-column">
                                                                <div class="m-b-25"
                                                                    style="height: 200px; width : 250px">
                                                                    <img style="width: 100%; aspect-ratio:3/2 ; object-fit : cover"
                                                                        src="{{data.userImage}}" class="img-radius"
                                                                        alt="User-Profile-Image" />
                                                                </div>
                                                                <h6 class="f-w-600">{{data.username}}</h6>
                                                                <p>{{data.descriptionForTick}}</p>

                                                                <h6 class="text-muted f-w-400">
                                                                    <form action="/approved_notapproved" method="post">
                                                                        {{#if data.isApproved}}
                                                                        <input type="hidden" name="id"
                                                                            value="{{data.userId}}">
                                                                        <button class="btn btn-official">Is
                                                                            Approved</button>
                                                                        {{else}}
                                                                        <input type="hidden" name="id"
                                                                            value="{{data.userId}}">
                                                                        <button class="btn btn-not-official">Is
                                                                            Not Approved</button>
                                                                        {{/if}}
                                                                    </form>

                                                                </h6>
                                                                {{!-- <i class="feather icon-edit m-t-10 f-16"></i> --}}

                                                                {{!-- <div>
                                                                    <h3>Approval</h3>
                                                                    <form action="/officials" method="post">
                                                                        {{#if isOfficails}}
                                                                        <input type="hidden" name="id"
                                                                            value="{{this._id}}">

                                                                        <button class="btn bg-c-green"
                                                                            style=" font-weight: bold; color :dark-black; font-size: 10px ; border-radius :12px "
                                                                            type="submit">Is_Official</button>
                                                                        {{else}}
                                                                        <input type="hidden" name="id"
                                                                            value="{{this._id}}">

                                                                        <button class="btn bg-c-pink"
                                                                            style="color :dark-black  ;font-size: 10px ;  border-radius  : 12px"
                                                                            type="submit">Is_Not_Official</button>
                                                                        {{/if}}

                                                                    </form>
                                                                </div> --}}
                                                            </div>
                                                        </div>
                                                        <div class="col-sm-8">
                                                            <div class="card-block">

                                                                <div class="embed-responsive embed-responsive-16by9">
                                                                    <video class="embed-responsive-item" controls>
                                                                        <source src={{data.videoRecord}}
                                                                            type="video/mp4">
                                                                        Your browser does not support the video tag.
                                                                    </video>
                                                                </div>
                                                                <br>
                                                                <h6 class="m-b-20 p-b-5 b-b-default f-w-600">
                                                                    Information
                                                                </h6>
                                                                <div class="row">
                                                                    <div class="col-sm-6">
                                                                        <p class="m-b-10 f-w-600">Email</p>
                                                                        <h6 class="text-muted f-w-400">
                                                                            <a href="https://demo.dashboardpack.com/cdn-cgi/l/email-protection"
                                                                                class="__cf_email__"
                                                                                data-cfemail="b4ded1dacdf4d3d9d5ddd89ad7dbd9">{{data.email}}</a>
                                                                        </h6>
                                                                    </div>
                                                                    <div class="col-sm-6">
                                                                        <p class="m-b-10 f-w-600">Phone</p>
                                                                        <h6 class="text-muted f-w-400">
                                                                            {{data.mobile}}
                                                                        </h6>
                                                                    </div>
                                                                </div>
                                                                <h6 class="m-b-20 m-t-40 p-b-5 b-b-default f-w-600">
                                                                    Approval
                                                                </h6>
                                                                <div class="row">
                                                                    <div class="col-sm-6">
                                                                        <p class="m-b-10 f-w-600">Applying Date</p>
                                                                        <h6 class="text-muted f-w-400">
                                                                            {{data.date}}
                                                                        </h6>
                                                                    </div>
                                                                    <div class="col-sm-6">
                                                                        <p class="m-b-10 f-w-600">Status</p>

                                                                        <span
                                                                            class="label  {{#if (if_eq data.forTickStatus 3)}}label-primary{{/if}}{{#if (if_eq data.forTickStatus 1)}}label-success{{/if}}{{#if (if_eq data.forTickStatus 2)}}label-danger{{/if}} text-uppercase">{{data.forTickStatus}}</span>
                                                                    </div>
                                                                </div>

                                                                <h6 class="m-b-20 m-t-40 p-b-5 b-b-default f-w-600">
                                                                    Certificate
                                                                </h6>

                                                                <div class="image_div">
                                                                    {{#each data.uploadCertificate}}
                                                                    <div class="image_div_inner">
                                                                        <img src="{{this.image}}" alt="Certificate" />
                                                                    </div>
                                                                    {{/each}}
                                                                </div>


                                                                <ul class="social-link list-unstyled m-t-40 m-b-10">
                                                                    <li>
                                                                        <a href="#!" target="_blank"
                                                                            data-toggle="tooltip"
                                                                            data-placement="bottom" title=""
                                                                            data-original-title="tiktok">
                                                                            <i class="fa-brands fa-tiktok"
                                                                                aria-hidden="true"></i></a>
                                                                    </li>
                                                                    <li>
                                                                        <a href="{{data.xtwitterUserName}}"
                                                                            target="_blank" data-toggle="tooltip"
                                                                            data-placement="bottom" title=""
                                                                            data-original-title="twitter"><i
                                                                                class="feather icon-twitter twitter"
                                                                                aria-hidden="true"></i></a>
                                                                    </li>
                                                                    <li>
                                                                        <a href="{{data.instagramUserName}}"
                                                                            target="_blank" data-toggle="tooltip"
                                                                            data-placement="bottom" title=""
                                                                            data-original-title="instagram"><i
                                                                                class="feather icon-instagram instagram"
                                                                                aria-hidden="true"></i></a>
                                                                    </li>
                                                                </ul>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>